{
  "version": 2,
  "routes": [
    {
      "src": "/flyer/(.*)/(.*)",
      "dest": "/api/flyer?flyerId=$1&productId=$2"
    },
    {
      "src": "/offer/(.*)",
      "dest": "/api/offer?offerId=$1"
    },
    {
      "src": "/banner/(.*)",
      "dest": "/api/banner?bannerId=$1"
    },
    {
      "src": "/deal/(.*)",
      "dest": "/api/deal?dealId=$1"
    },
    {
      "src": "/refer/(.*)",
      "dest": "/api/refer?code=$1"
    }
  ]
}
